mode compile

// Test 7+ parameters (should use stack for args 7+)
func add7(a: i32, b: i32, c: i32, d: i32, e: i32, f: i32, g: i32) i32:
    return a + b + c + d + e + f + g

func main() i32:
    result: i32 = add7(1, 2, 3, 4, 5, 6, 7)
    // Expected: 1+2+3+4+5+6+7 = 28
    when result == 28:
        give 0
    give 1
