mode compile

// Test function with parameters and return value
func add(a: i32, b: i32) i32:
    return a + b

// Test update parameter
func double(update x: i32):
    x = x * 2

// Test main with multiple function calls
func main() i32:
    // Test basic parameter passing
    result: i32 = add(10, 32)
    
    // Test update parameter
    num: i32 = 21
    double(num)
    
    // num should now be 42
    // Return 0 if correct, 1 if wrong
    when num == 42:
        give 0
    give 1
