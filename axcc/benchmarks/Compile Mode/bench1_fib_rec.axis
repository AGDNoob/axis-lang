// Benchmark 1: Recursive Fibonacci
// Tests: function call overhead, recursion, stack management
// ~63 million recursive calls for fib(38)
mode compile
func fib(n: i32) i32:
    when n <= 1:
        return n
    return fib(n - 1) + fib(n - 2)
func main() i32:
    r: i32 = fib(38)
    return r & 255
