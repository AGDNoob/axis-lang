// Benchmark 3: Nested Loop with Data-Dependent Computation
// Tests: loop efficiency, multiply, XOR, data dependency chain
// 100 million iterations (10000 x 10000)
mode compile
func main() i32:
    sum: i32 = 0
    i: i32 = 0
    j: i32 = 0
    t: i32 = 0
    while i < 10000:
        j = 0
        while j < 10000:
            t = sum * 7 + i * j
            sum = t ^ (i + j)
            j = j + 1
        i = i + 1
    return (sum >> 24) & 255
