mode script

# Nested field test
Vec2: field:
    x: i32 = 0
    y: i32 = 0

Player: field:
    name: str = "Unknown"
    health: i32 = 100
    position: Vec2

# Create a Player instance
p: Player
writeln("Initial player:")
writeln(p.name)
writeln(p.health)
writeln(p.position.x)
writeln(p.position.y)

# Modify the player
p.name = "Hero"
p.health = 200
p.position.x = 50
p.position.y = 75
writeln("Modified player:")
writeln(p.name)
writeln(p.health)
writeln(p.position.x)
writeln(p.position.y)
