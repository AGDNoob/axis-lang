// Test: Arrays — init, index, assign, iteration, multi-element
mode compile

func sum_array(arr: (i32; 5)) i32:
    total: i32 = arr[0] + arr[1] + arr[2] + arr[3] + arr[4]
    return total
func main() i32:
    // Basic init and access
    a: (i32; 5) = [10, 20, 30, 40, 50]
    when a[0] != 10:
        return 1
    when a[4] != 50:
        return 2
    // Index assignment
    a[2] = 99
    when a[2] != 99:
        return 3
    // Other elements unchanged
    when a[0] != 10:
        return 4
    when a[1] != 20:
        return 5
    // Sum via function
    b: (i32; 5) = [1, 2, 3, 4, 5]
    when sum_array(b) != 15:
        return 6
    // For-each
    total: i32 = 0
    for x in a:
        total += x
    // 10 + 20 + 99 + 40 + 50 = 219
    when total != 219:
        return 7
    // Small arrays
    tiny: (i32; 1) = [42]
    when tiny[0] != 42:
        return 8
    // Compound assignment on array element
    c: (i32; 3) = [10, 20, 30]
    c[1] += 5
    when c[1] != 25:
        return 9
    return 0