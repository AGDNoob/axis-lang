// Test: while and repeat loops, stop/skip
mode compile

func main() i32:
    // Basic while countdown
    count: i32 = 10
    sum: i32 = 0
    while count > 0:
        sum += count
        count -= 1
    // sum of 1..10 = 55
    when sum != 55:
        return 1
    // While with stop (break)
    i: i32 = 0
    while i < 100:
        when i == 7:
            stop
        i += 1
    when i != 7:
        return 2
    // While with skip (continue)
    sum = 0
    j: i32 = 0
    while j < 10:
        j += 1
        when j % 2 == 0:
            skip
        sum += j
    // sum of odd numbers 1..9 = 1+3+5+7+9 = 25
    when sum != 25:
        return 3
    // repeat with stop
    k: i32 = 0
    repeat:
        k += 1
        when k >= 50:
            stop
    when k != 50:
        return 4
    // Nested while
    total: i32 = 0
    a: i32 = 0
    while a < 5:
        b: i32 = 0
        while b < 5:
            total += 1
            b += 1
        a += 1
    when total != 25:
        return 5
    return 0