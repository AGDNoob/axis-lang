// Test: GCD (Euclidean algorithm) and LCM — inlined in main
// (while loops in helper functions trigger unresolved label bug)
mode compile
func main() i32:
    // GCD(12, 8) = 4
    x: i32 = 12
    y: i32 = 8
    while y != 0:
        temp: i32 = y
        y = x % y
        x = temp
    when x != 4:
        return 1
    // GCD(100, 75) = 25
    x = 100
    y = 75
    while y != 0:
        temp2: i32 = y
        y = x % y
        x = temp2
    when x != 25:
        return 2
    // GCD(17, 13) = 1 (coprime)
    x = 17
    y = 13
    while y != 0:
        temp3: i32 = y
        y = x % y
        x = temp3
    when x != 1:
        return 3
    // GCD(0, 5) = 5
    x = 0
    y = 5
    while y != 0:
        temp4: i32 = y
        y = x % y
        x = temp4
    when x != 5:
        return 4
    // LCM(12, 8) = 24 via lcm = a / gcd(a,b) * b
    x = 12
    y = 8
    while y != 0:
        temp5: i32 = y
        y = x % y
        x = temp5
    lcm: i32 = (12 / x) * 8
    when lcm != 24:
        return 5
    // GCD of same number = itself
    x = 42
    y = 42
    while y != 0:
        temp6: i32 = y
        y = x % y
        x = temp6
    when x != 42:
        return 6
    return 0