// Test: for loops — range, step, array iteration
mode compile

func main() i32:
    // Simple range
    sum: i32 = 0
    for i in range(1, 11):
        sum += i
    // 1+2+...+10 = 55
    when sum != 55:
        return 1
    // Range with step
    sum = 0
    for i in range(0, 20, 3):
        sum += i
    // 0+3+6+9+12+15+18 = 63
    when sum != 63:
        return 2
    // For loop with stop
    sum = 0
    for i in range(0, 100):
        when i >= 5:
            stop
        sum += i
    // 0+1+2+3+4 = 10
    when sum != 10:
        return 3
    // For loop with skip
    sum = 0
    for i in range(0, 10):
        when i % 2 == 0:
            skip
        sum += i
    // 1+3+5+7+9 = 25
    when sum != 25:
        return 4
    // For-each over array
    nums: (i32; 5) = [10, 20, 30, 40, 50]
    sum = 0
    for x in nums:
        sum += x
    when sum != 150:
        return 5
    // Nested for
    total: i32 = 0
    for i in range(0, 4):
        for j in range(0, 4):
            total += 1
    when total != 16:
        return 6
    return 0