{
  "name": "axis-language",
  "displayName": "AXIS Language Support",
  "description": "Syntax highlighting for AXIS - value-oriented system programming language (script & compile)",
  "version": "0.5.0",
  "publisher": "axis-lang",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "axis",
    "systems",
    "compiler",
    "transpiler",
    "script",
    "x86-64",
    "value-oriented",
    "enum",
    "match",
    "for-loop",
    "field",
    "syntax-highlighting"
  ],
  "contributes": {
    "languages": [
      {
        "id": "axis",
        "aliases": [
          "AXIS",
          "axis"
        ],
        "extensions": [
          ".axis"
        ],
        "icon": {
          "light": "./icons/axis-light.svg",
          "dark": "./icons/axis-dark.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "axis",
        "scopeName": "source.axis",
        "path": "./syntaxes/axis.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "axis",
        "path": "./snippets/axis.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AGDNoob/axis-lang"
  },
  "license": "MIT"
}
