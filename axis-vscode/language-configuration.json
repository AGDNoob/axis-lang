{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "colorizedBracketPairs": [
    ["(", ")"],
    ["[", "]"]
  ],
  "folding": {
    "offSide": true
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(func|when|else|else\\s+when|while|loop|repeat|match|field|enum|for)\\b.*:\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*(func|when|else|else\\s+when|while|loop|repeat|match|field|enum|for)\\b.*:\\s*//.*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*\\S.*:\\s*$",
      "afterText": "^\\s*$",
      "action": { "indent": "indent" }
    }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(func|when|else|while|loop|repeat|match|field|enum|for)\\b.*:\\s*(//.*)?$",
    "decreaseIndentPattern": "^\\s*(else|stop|break|skip|continue|give|return)\\b"
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}
