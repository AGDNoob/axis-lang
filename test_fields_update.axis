mode script

# Test update modifier with fields

Vec2: field:
    x: i32 = 0
    y: i32 = 0

func move(update pos: Vec2, dx: i32, dy: i32):
    pos.x = pos.x + dx
    pos.y = pos.y + dy

func reset(update pos: Vec2):
    pos.x = 0
    pos.y = 0

# Create position
player_pos: Vec2
player_pos.x = 10
player_pos.y = 20
writeln("Initial position:")
writeln(player_pos.x)
writeln(player_pos.y)

# Move the position using update
move(player_pos, 5, 3)
writeln("After move(5, 3):")
writeln(player_pos.x)
writeln(player_pos.y)

# Reset position
reset(player_pos)
writeln("After reset:")
writeln(player_pos.x)
writeln(player_pos.y)

writeln("SUCCESS!")
