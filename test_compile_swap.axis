mode compile

// Test multiple update parameters (swap)
func swap(update a: i32, update b: i32):
    temp: i32 = a
    a = b
    b = temp

func main() i32:
    x: i32 = 10
    y: i32 = 20
    swap(x, y)
    // After swap: x should be 20, y should be 10
    when x == 20:
        when y == 10:
            give 0
    give 1
