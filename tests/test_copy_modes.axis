mode script
// Test copy modes

// Test default copy (runtime mode)
arr1: (i32; 3) = [1, 2, 3]
arr2: (i32; 3) = copy arr1
arr2[0] = 999
writeln(arr1[0])  // Should be 1 (unchanged)
writeln(arr2[0])  // Should be 999

// Test copy.runtime (explicit)
arr3: (i32; 3) = [10, 20, 30]
arr4: (i32; 3) = copy.runtime arr3
arr4[0] = 888
writeln(arr3[0])  // Should be 10 (unchanged)
writeln(arr4[0])  // Should be 888

// Test copy.compile
arr5: (i32; 3) = [100, 200, 300]
arr6: (i32; 3) = copy.compile arr5
arr6[0] = 777
writeln(arr5[0])  // Should be 100 (unchanged)
writeln(arr6[0])  // Should be 777

// Test with fields
Vec2: field:
    x: i32 = 0
    y: i32 = 0

v1: Vec2
v1.x = 50
v1.y = 60

v2: Vec2 = copy v1
v2.x = 111
writeln(v1.x)  // Should be 50 (unchanged)
writeln(v2.x)  // Should be 111

v3: Vec2 = copy.runtime v1
v3.x = 222
writeln(v1.x)  // Should be 50 (unchanged)
writeln(v3.x)  // Should be 222

v4: Vec2 = copy.compile v1
v4.x = 333
writeln(v1.x)  // Should be 50 (unchanged)
writeln(v4.x)  // Should be 333
