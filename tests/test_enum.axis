mode script
// Test enum feature

// Default underlying type (i32)
Color: enum:
    Red
    Green
    Blue

// Explicit values with default type
Status: enum:
    Pending = 0
    Active = 1
    Completed = 100
    Archived = 200

// Typed enum (u8)
Priority: enum u8:
    Low
    Medium
    High

// Typed enum (i64)
BigEnum: enum i64:
    Small = 0
    Large = 1000000

// Test basic enum usage
c: Color = Color.Red
writeln(c)  // Should print 0

c = Color.Green
writeln(c)  // Should print 1

c = Color.Blue
writeln(c)  // Should print 2

// Test enum with explicit values
s: Status = Status.Pending
writeln(s)  // Should print 0

s = Status.Active
writeln(s)  // Should print 1

s = Status.Completed
writeln(s)  // Should print 100

s = Status.Archived
writeln(s)  // Should print 200

// Test typed enum (u8)
p: Priority = Priority.High
writeln(p)  // Should print 2

// Test typed enum (i64)
b: BigEnum = BigEnum.Large
writeln(b)  // Should print 1000000

