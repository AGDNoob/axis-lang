mode script

# Test arrays of named field types

Vec2: field:
    x: i32 = 0
    y: i32 = 0

Player: field:
    name: str = "Unknown"
    position: Vec2

# Array of named field types
players: (Player; 3)

# Initialize players
players[0].name = "Alice"
players[0].position.x = 10
players[0].position.y = 20

players[1].name = "Bob"
players[1].position.x = 30
players[1].position.y = 40

players[2].name = "Charlie"
players[2].position.x = 50
players[2].position.y = 60

# Print all players
i: i32 = 0
while i < 3:
    writeln("Player:")
    writeln(players[i].name)
    writeln("Position:")
    writeln(players[i].position.x)
    writeln(players[i].position.y)
    writeln("")
    i = i + 1
