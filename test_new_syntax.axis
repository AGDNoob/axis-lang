mode script

# Test new function syntax
func add(a: i32, b: i32) i32:
    return a + b

# Test update modifier
func increment(update x: i32):
    x = x + 1

# Test arrays
arr: (i32; 5) = [10, 20, 30, 40, 50]

# Test function calls
result: i32 = add(5, 10)
writeln(result)

# Test update
y: i32 = 100
increment(y)
writeln(y)
