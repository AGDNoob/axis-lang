mode script

# Comprehensive field test with inline fields

# Define a game with nested inline fields
Game: field:
    title: str = "Championship"
    
    home: field:
        name: str = ""
        score: i32 = 0
        
        players: (field; 11): [
            name: str = ""
            number: i32 = 0
            
            position: field:
                x: i32 = 0
                y: i32 = 0
        ]
    away: field:
        name: str = ""
        score: i32 = 0

# Create the game
game: Game
writeln("Initial game title:")
writeln(game.title)

# Set team names
game.home.name = "Eagles"
game.away.name = "Lions"

# Set up a player
game.home.players[0].name = "Player One"
game.home.players[0].number = 10
game.home.players[0].position.x = 50
game.home.players[0].position.y = 25

# Update score
game.home.score = 3
game.away.score = 2

# Print results
writeln("Home team:")
writeln(game.home.name)
writeln("Score:")
writeln(game.home.score)
writeln("Player 0:")
writeln(game.home.players[0].name)
writeln("Number:")
writeln(game.home.players[0].number)
writeln("Position X:")
writeln(game.home.players[0].position.x)
writeln("Position Y:")
writeln(game.home.players[0].position.y)

writeln("Away team:")
writeln(game.away.name)
writeln("Score:")
writeln(game.away.score)
